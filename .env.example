# Copie ce fichier en .env et remplis avec tes vraies valeurs.
# Le .env est ignoré par git (voir .gitignore ligne 6), il ne sera jamais commité.
#
# Usage : cp .env.example .env  puis édite .env

# Clé API Gemini (obligatoire)
# Obtiens-la sur https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Mode par défaut pour pgp-full (optionnel, default: draft)
# Valeurs possibles: draft | final
PGP_DEFAULT_MODE=draft

# Override du dossier data (optionnel)
# Laisse vide pour utiliser ${CLAUDE_PLUGIN_ROOT}/data
PGP_DATA_DIR=
